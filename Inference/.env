##################### General Configuration ####################
# 4 for Quantum Annealing (D-Wave), 16 for Simulated Annealing
NUM_THREADS=4 


# Dataset directory (relative to Inference/). Supported: Datasets/Datasets_balanced, Datasets/Datasets_unbalanced
DATASETS_DIR=Datasets/Datasets_unbalanced

# Initial parameters
LAMBDA_INIT=1
OFFSET_INIT=1

# Hidden nodes initialization (function/offset mode only)
HIDDEN_NODES_OFFSET_VALUE=-0.02

# Learning rates (tuned for 2D XOR on simulated annealing)
LEARNING_RATE_GAMMA=0.01
LEARNING_RATE_LAMBDA=0.02
LEARNING_RATE_OFFSET=0.03
LEARNING_RATE_COMBINER=0.02

# Annealer selection (supported values: simulated, quantum, exact). Default: simulated.
ANNEALER_TYPE=simulated

# D-Wave Leap profile name (used only when ANNEALER_TYPE=quantum).
# Must match a profile in ~/.config/dwave/dwave.conf (created via `dwave config create`).
DWAVE_PROFILE=defaults

# Annealing Settings
NUM_READS=1
SA_NUM_SWEEPS=1000
SA_SWEEPS_PER_BETA=1
SA_BETA_MIN=1
SA_BETA_MAX=10

# Training
# EPOCHS / N_SAMPLES_PER_REGION are kept small so a single 2D-XOR run is also
# QPU-viable: one run of both models = EPOCHS*train*(1 + 3 nodes) + eval calls.
# With epochs=25, n/region=20 -> ~6.5k annealer calls (~2.3 min QPU access).
EPOCHS=25
BATCH_SIZE=16 # Set to a large number to use the entire dataset as one batch
RANDOM_SEED=42
PRINT_INTERVAL=5

# K-Fold Cross Validation
K_FOLDS=5

#xor parameters
N_SAMPLES_PER_REGION=20
TEST_SIZE=0.2

##################### Modular Network Configuration ###############################
# Whether to partition the input among the Ising Perceptrons or not.
PARTITION_INPUT=False

# Number of Ising Perceptrons in the Modular Network
NUM_ISING_PERCEPTRONS=5
# Model Size (-1 for auto). If auto, the code uses MINIMUM_MODEL_SIZE when needed.
# -1 -> max(n_features, MINIMUM_MODEL_SIZE); for 2D XOR this gives 8 spins (small,
# stable, embeds cleanly). NOTE: the UCI suite has datasets up to 44 features,
# which auto-sizing handles; do not hardcode MODEL_SIZE to a small value there.
MODEL_SIZE=-1
MINIMUM_MODEL_SIZE=8
