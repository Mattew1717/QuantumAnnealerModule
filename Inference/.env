##################### General Configuration ####################
NUM_THREADS=16

# Initial parameters
LAMBDA_INIT=1
OFFSET_INIT=1

# Hidden nodes initialization (function/offset mode only)
HIDDEN_NODES_OFFSET_VALUE=-0.02

# Learning rates
LEARNING_RATE_GAMMA=0.001
LEARNING_RATE_LAMBDA=0.005
LEARNING_RATE_OFFSET=0.01
LEARNING_RATE_COMBINER=0.005

# Annealer selection (supported values: simulated, quantum, exact)
ANNEALER_TYPE=simulated

# Annealing Settings
NUM_READS=1
SA_NUM_SWEEPS=1000
SA_SWEEPS_PER_BETA=1
SA_BETA_MIN=1
SA_BETA_MAX=10

# Training
EPOCHS=200
BATCH_SIZE=32 # Set to a large number to use the entire dataset as one batch
RANDOM_SEED=42
VALIDATION_INTERVAL=5

# K-Fold Cross Validation
K_FOLDS=5

#xor parameters
N_SAMPLES_PER_REGION=100
TEST_SIZE=0.2

##################### Modular Network Configuration ###############################
# Whether to partition the input among the Ising Perceptrons or not.
PARTITION_INPUT=False

# Number of Ising Perceptrons in the Modular Network
NUM_ISING_PERCEPTRONS=5
# Model Size (-1 for auto). If auto, the code uses MINIMUM_MODEL_SIZE when needed.
MODEL_SIZE=50
MINIMUM_MODEL_SIZE=50
